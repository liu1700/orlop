/bin

dist/


# Go build artifacts (don't commit) — both the in-cmd output path and the
# top-level path produced by `go build ./cmd/...` run from the module root.
cmd/orlop-server/orlop-server
cmd/orlop-control/orlop-control
cmd/orlop-spawner/orlop-spawner
/orlop-server
/orlop-control
/orlop-spawner
/orlop

# Bench harness output (issue #74). Per-revision JSON / sweep dirs not committed.
bench-results/*
!bench-results/.gitkeep
!bench-results/*.md
.vercel

# Minisign private keys — must never be committed. Keep them outside the
# repo (or at least never tracked).
*.minisign.key
orlop-minisign.key

# Generated by `orlop skill inject` when running e2e against a local mount.
# The injected file points at /tmp/orlop-e2e/mnt2 — not a real production
# AGENTS.md.
AGENTS.md

# pjdfstest raw results (regenerate via scripts/pjdfstest-docker.sh)
pjdfstest-results/
