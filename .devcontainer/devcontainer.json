{
  "name": "orlop",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.25"
    },
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest",
      "profile": "default"
    }
  },
  // Linux mount client links libfuse3; pkg-config is needed for its build probe.
  // Then pre-fetch both sides' deps via `make setup`.
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y libfuse3-dev pkg-config",
  "postCreateCommand": "make setup",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "rust-lang.rust-analyzer"
      ]
    }
  }
}
